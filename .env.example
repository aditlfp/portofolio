# Choose one provider: sqlite, mongodb, or supabase
DB_PROVIDER=sqlite

# SQLite configuration
# Only needed for sqlite provider. Defaults to database.sqlite in the project root.
SQLITE_PATH=./database.sqlite

BLOB_READ_WRITE_TOKEN=vercel_***

# MongoDB configuration
# Use only for DB_PROVIDER=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portfolio

# Supabase configuration
# Use only for DB_PROVIDER=supabase
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Or for read-only access from browser-safe contexts, use SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=your-anon-key

# General settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
JWT_SECRET=replace-with-a-secure-secret

# Default admin account (required for first login seed)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-password
