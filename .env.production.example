# Production Environment Example
# Copy this to .env.production.local and fill in your values
# DO NOT COMMIT .env.production.local to git!

# ============== DATABASE CONFIGURATION ==============

# Choice: sqlite | mongodb | supabase
# For production, mongodb is recommended
DB_PROVIDER=mongodb

# MongoDB Atlas Connection
# Get this URL from: https://cloud.mongodb.com > Connect > Application
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://prod_user:your_secure_password@your-cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB Database Name
MONGODB_DB=portfolio_production

# ============== SECURITY ==============

# JWT Secret for authentication (minimum 32 characters, use random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-jwt-secret-minimum-32-characters-long

# ============== DEPLOYMENT ==============

# Production domain (used in emails, links, etc)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Node environment
NODE_ENV=production

# ============== OPTIONAL: SUPABASE ==============
# Only if using Supabase instead of MongoDB

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============== SECURITY NOTES ==============
# ⚠️  Keep this file secure - never commit to version control
# ⚠️  Use strong passwords with special characters
# ⚠️  Change default admin credentials after first login
# ⚠️  Rotate secrets periodically
# ⚠️  Use your platform's secret manager (GitHub Secrets, Vercel KV, etc)
